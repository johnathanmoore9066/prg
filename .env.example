# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.

# Neon Postgres — pooled connection string.
# Local dev: use a Neon "dev" branch. Production (Vercel env vars): the main branch.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT signing key for staff sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Resend (https://resend.com) — API key for notification emails.
RESEND_API_KEY=

# Where form-notification emails go. Per-form destinations live in
# api/_lib/notify.js (DESTINATIONS) and all default to this address for now.
NOTIFY_EMAIL_DEFAULT=johnathanmoore9066@gmail.com

# Sender. onboarding@resend.dev works without domain verification but only
# delivers to the Resend account owner's address. After verifying
# prgtriangle.com (or a subdomain), switch to e.g. "PRG <notify@prgtriangle.com>".
RESEND_FROM=PRG Property Management <onboarding@resend.dev>

# First dashboard user — consumed by `npm run db:setup` (re-run with new
# values to add teammates; existing users are never overwritten).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
